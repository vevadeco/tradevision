# ─── Clerk Auth (required) ───
# Create app at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Database (required for user progress) ───
# Neon Postgres (recommended) or Vercel Postgres
# Example: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/tradevision

# ─── MEXC API (optional — public klines work without keys) ───
MEXC_API_KEY=your_mexc_access_key
MEXC_API_SECRET=your_mexc_secret_key
